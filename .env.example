# Supabase — from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to browser

# Google Maps — from https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# App URL (used by Supabase Auth redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
